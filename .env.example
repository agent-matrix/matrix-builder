APP_NAME=matrix-builder
APP_ENV=development
APP_VERSION=0.8.0-batch.8
LOG_LEVEL=INFO
JSON_LOGS=true
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000
CONTENT_SECURITY_POLICY=default-src 'self'; frame-ancestors 'none'; base-uri 'self'
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=40
RATE_LIMIT_BUNDLE_REQUESTS_PER_HOUR=20
SESSION_COOKIE_NAME=matrix_builder_session
SESSION_TTL_SECONDS=86400
SESSION_SIGNING_KEY=dev-only-session-key-change-before-production
AGENT_GENERATOR_MODE=mock
MATRIX_DEFINITIONS_MODE=mock
MATRIXHUB_MODE=dry-run
PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
SIGNED_URL_TTL_SECONDS=172800
SIGNED_URL_SECRET=dev-only-change-me
GUEST_BUNDLES_PER_DAY=3
FREE_BUNDLES_PER_MONTH=20
GUEST_BUNDLE_TTL_SECONDS=172800
FREE_BUNDLE_TTL_SECONDS=2592000
STORAGE_BACKEND=local
STORAGE_ROOT=.local/matrix-builder-storage
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=matrix-builder-bundles
S3_ACCESS_KEY_ID=matrix_builder
S3_SECRET_ACCESS_KEY=matrix_builder_dev_password
# --- Persistence: Aiven PostgreSQL (ADR 0002) ---------------------------------------------
# The app connects as a NON-superuser role (matrix_app) so row-level security isolates rows
# per user; avnadmin is used only to run migrations. Secrets live here / in your secret store
# — never in git. Rotate anything that leaks. Aiven requires TLS (sslmode=require).
DATABASE_URL=postgresql+psycopg://matrix_app:CHANGE_ME@pg-3113274d-matrix-builder.a.aivencloud.com:23188/defaultdb?sslmode=require
# Used ONLY by `alembic upgrade head` (the privileged role that owns the schema):
MIGRATION_DATABASE_URL=postgresql+psycopg://avnadmin:CHANGE_ME@pg-3113274d-matrix-builder.a.aivencloud.com:23188/defaultdb?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
# --- Auth: self-issued HS256 JWT (no external IdP; ADR 0002) -------------------------------
MB_JWT_SECRET=dev-only-change-me
MB_JWT_AUDIENCE=authenticated
# Sign in with Google: the backend verifies the Google ID token against this Web client ID,
# then mints the MB_JWT above. Leave empty to disable. (Console: OAuth 2.0 Client IDs.)
GOOGLE_CLIENT_ID=
# Passwordless email sign-in (magic link) via Resend. RESEND_API_KEY enables real delivery
# (unset = dev mode: the link is logged). EMAIL_FROM must be a verified Resend sender/domain.
# PUBLIC_APP_URL is where the magic link points (this app's public origin).
RESEND_API_KEY=
EMAIL_FROM=Matrix Builder <onboarding@resend.dev>
PUBLIC_APP_URL=https://builder.matrixhub.io
EMAIL_LINK_TTL_SECONDS=900
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=matrix-builder-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
AUDIT_LOG_PATH=.local/audit/audit-events.jsonl
