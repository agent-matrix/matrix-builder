{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrixhub.io/schemas/matrix-designer/blueprint-details.schema.json",
  "title": "blueprint-details",
  "description": "The full Blueprint Details package the Matrix Builder Details page renders for one chosen blueprint candidate. Produced by Matrix Designer's multi-agent brain; mirrors the Details page data model so agent output drops straight into the UI.",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidate_id", "overview", "architecture", "batches", "file_plan", "matrix_rules"],
  "properties": {
    "candidate_id": { "type": "string", "enum": ["minimal", "standard", "production"] },
    "overview": { "type": "string", "minLength": 1 },
    "architecture": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "purpose", "allowed_files", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^batch-[0-9]{2,}$" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "tasks": { "type": "array", "items": { "type": "string" }, "default": [] },
          "allowed_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" }, "default": [] },
          "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "validation_checks": { "type": "array", "items": { "type": "string" }, "default": [] },
          "must_not_change": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    },
    "file_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "matrix_rules": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "default": [] },
    "validation_plan": { "type": "array", "items": { "type": "string" }, "default": [] },
    "risks": { "type": "array", "items": { "type": "string" }, "default": [] },
    "assumptions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "design_brain": { "type": ["string", "null"] },
    "chat_history": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "content"],
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "blueprint"] },
          "content": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      }
    }
  }
}
