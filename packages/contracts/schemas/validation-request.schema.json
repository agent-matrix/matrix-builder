{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrixhub.io/schemas/matrix-builder/validation-request.schema.json",
  "title": "validation-request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "changed_files",
    "dependency_changes",
    "artifacts",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "matrix.builder.validation-request/v1"
    },
    "bundle_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "bundle",
        "patch",
        "repository",
        "dry-run"
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "status"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "added",
              "modified",
              "deleted",
              "renamed"
            ]
          },
          "digest": {
            "type": [
              "string",
              "null"
            ]
          },
          "previous_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "dependency_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ecosystem",
          "name",
          "action",
          "approved"
        ],
        "properties": {
          "ecosystem": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "added",
              "updated",
              "removed"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "approved": {
            "type": "boolean"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "verified"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": [
              "string",
              "null"
            ]
          },
          "verified": {
            "type": "boolean"
          }
        }
      }
    },
    "standards_lock_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "matrix_blueprint_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "repository_archive_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "patch_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    }
  }
}