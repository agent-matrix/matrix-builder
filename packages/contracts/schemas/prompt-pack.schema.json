{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrixhub.io/schemas/matrix-builder/prompt-pack.schema.json",
  "title": "prompt-pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prompt_pack_id",
    "bundle_id",
    "blueprint_id",
    "default_coder",
    "prompts"
  ],
  "properties": {
    "prompt_pack_id": {
      "type": "string",
      "minLength": 3
    },
    "bundle_id": {
      "type": "string",
      "minLength": 3
    },
    "blueprint_id": {
      "type": "string",
      "minLength": 3
    },
    "default_coder": {
      "$ref": "#/$defs/coderId"
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "coder",
          "label",
          "path",
          "content",
          "contract_files"
        ],
        "properties": {
          "coder": {
            "$ref": "#/$defs/coderId"
          },
          "label": {
            "type": "string"
          },
          "path": {
            "$ref": "#/$defs/matrixFilePath"
          },
          "content": {
            "type": "string",
            "minLength": 20
          },
          "contract_files": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/matrixFilePath"
            }
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/matrixFilePath"
            },
            "default": []
          },
          "validation_commands": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "hard_constraints": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    }
  },
  "$defs": {
    "buildType": {
      "type": "string",
      "enum": [
        "app",
        "agent",
        "api"
      ]
    },
    "goal": {
      "type": "string",
      "enum": [
        "portfolio",
        "startup-mvp",
        "internal-tool",
        "learning",
        "open-source",
        "enterprise"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "coderId": {
      "type": "string",
      "enum": [
        "claude-code",
        "codex-chatgpt",
        "cursor",
        "gitpilot",
        "ibm-bob",
        "generic-ai-coder"
      ]
    },
    "validationStatus": {
      "type": "string",
      "enum": [
        "not-run",
        "approved",
        "needs-repair",
        "rejected"
      ]
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{16,}$"
    },
    "matrixFilePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._/@+:-][A-Za-z0-9._/@+:/ -]*$"
    },
    "apiRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "summary": {
          "type": "string"
        },
        "auth_required": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "bundleFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "required"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/matrixFilePath"
        },
        "kind": {
          "type": "string",
          "enum": [
            "control",
            "source",
            "test",
            "doc",
            "prompt",
            "config",
            "manifest",
            "artifact"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "content_type": {
          "type": "string",
          "default": "text/plain"
        },
        "digest": {
          "type": "string"
        }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "severity",
        "message"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 3
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
