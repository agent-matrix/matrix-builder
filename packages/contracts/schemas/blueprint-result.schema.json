{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrixhub.io/schemas/matrix-builder/blueprint-result.schema.json",
  "title": "blueprint-result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blueprint_id",
    "candidate_id",
    "name",
    "slug",
    "idea",
    "quality_level",
    "stack",
    "required_files",
    "tasks"
  ],
  "properties": {
    "blueprint_id": {
      "type": "string",
      "minLength": 3
    },
    "candidate_id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "idea": {
      "type": "string",
      "minLength": 5
    },
    "quality_level": {
      "$ref": "#/$defs/qualityLevel"
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frontend",
        "backend"
      ],
      "properties": {
        "frontend": {
          "type": "string"
        },
        "backend": {
          "type": "string"
        },
        "worker": {
          "type": [
            "string",
            "null"
          ]
        },
        "database": {
          "type": [
            "string",
            "null"
          ]
        },
        "auth": {
          "type": "string",
          "enum": [
            "none",
            "session",
            "oauth2",
            "enterprise-sso"
          ],
          "default": "none"
        },
        "deploy": {
          "type": "string",
          "enum": [
            "local",
            "docker",
            "cloud",
            "kubernetes"
          ],
          "default": "docker"
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "api_routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/apiRoute"
      },
      "default": []
    },
    "required_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixFilePath"
      },
      "minItems": 1
    },
    "allowed_change_roots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixFilePath"
      },
      "default": []
    },
    "forbidden_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixFilePath"
      },
      "default": []
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "allowed_files",
          "acceptance_criteria"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{3}$"
          },
          "title": {
            "type": "string"
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/matrixFilePath"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "acceptance_commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "standards_lock_ref": {
      "type": "string",
      "default": "MATRIX_STANDARDS.lock"
    }
  },
  "$defs": {
    "buildType": {
      "type": "string",
      "enum": [
        "app",
        "agent",
        "api"
      ]
    },
    "goal": {
      "type": "string",
      "enum": [
        "portfolio",
        "startup-mvp",
        "internal-tool",
        "learning",
        "open-source",
        "enterprise"
      ]
    },
    "qualityLevel": {
      "type": "string",
      "enum": [
        "starter",
        "standard",
        "production",
        "enterprise"
      ]
    },
    "coderId": {
      "type": "string",
      "enum": [
        "claude-code",
        "codex-chatgpt",
        "cursor",
        "gitpilot",
        "ibm-bob",
        "generic-ai-coder"
      ]
    },
    "validationStatus": {
      "type": "string",
      "enum": [
        "not-run",
        "approved",
        "needs-repair",
        "rejected"
      ]
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{16,}$"
    },
    "matrixFilePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._/@+:-][A-Za-z0-9._/@+:/ -]*$"
    },
    "apiRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "summary": {
          "type": "string"
        },
        "auth_required": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "bundleFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "required"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/matrixFilePath"
        },
        "kind": {
          "type": "string",
          "enum": [
            "control",
            "source",
            "test",
            "doc",
            "prompt",
            "config",
            "manifest",
            "artifact"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "content_type": {
          "type": "string",
          "default": "text/plain"
        },
        "digest": {
          "type": "string"
        }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "severity",
        "message"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 3
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
