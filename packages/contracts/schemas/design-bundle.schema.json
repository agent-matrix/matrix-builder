{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrixhub.io/schemas/matrix-designer/design-bundle.schema.json",
  "title": "design-bundle",
  "description": "The Design Brain. The governed artifact Matrix Designer produces from an idea (and optional references) BEFORE Matrix Builder turns it into blueprint candidates. It carries the full solution design so every later batch fits together: framework decision, visual/UX target, architecture, entity/data contracts, asset/UI manifest, acceptance criteria (including visual), and an ordered batch roadmap with ownership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "design_id",
    "project",
    "source",
    "goal_analysis",
    "framework_decision",
    "architecture",
    "acceptance",
    "batch_roadmap",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "matrix.designer.bundle/v1" },
    "design_id": { "type": "string", "minLength": 3 },
    "project": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,80}$" },
    "domain": {
      "type": "string",
      "enum": ["web-game", "web-app", "saas", "api", "agent", "cli", "library", "dashboard", "landing-page", "other"]
    },
    "build_type": { "type": "string", "enum": ["app", "agent", "api"] },
    "quality_level": { "$ref": "#/$defs/qualityLevel" },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idea"],
      "properties": {
        "idea": { "type": "string", "minLength": 5, "maxLength": 4000 },
        "idea_digest": { "$ref": "#/$defs/digest" },
        "references": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": { "type": "string", "enum": ["image", "pdf", "url", "repo", "figma", "text"] },
              "ref": { "type": "string", "minLength": 1 },
              "note": { "type": "string" }
            }
          }
        }
      }
    },

    "goal_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["real_goal", "complexity"],
      "properties": {
        "real_goal": { "type": "string", "minLength": 1 },
        "audience": { "type": "string" },
        "complexity": { "type": "string", "enum": ["trivial", "small", "medium", "large", "very-large"] },
        "missing_decisions": { "type": "array", "items": { "type": "string" }, "default": [] },
        "risks": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["risk", "severity"],
            "properties": {
              "risk": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "mitigation": { "type": "string" }
            }
          }
        }
      }
    },

    "framework_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stack", "rationale"],
      "properties": {
        "stack": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "rationale": { "type": "string", "minLength": 1 },
        "rejected": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["option", "why_not"],
            "properties": {
              "option": { "type": "string" },
              "why_not": { "type": "string" }
            }
          }
        },
        "deployment_target": { "type": "string", "enum": ["local", "docker", "cloud", "kubernetes", "static-pages"] }
      }
    },

    "visual_target": {
      "type": "object",
      "additionalProperties": false,
      "description": "The acceptance target for LOOK — the thing the existing pipeline cannot express today.",
      "properties": {
        "style": { "type": "string" },
        "palette": { "type": "array", "items": { "type": "string" }, "default": [] },
        "must_include": { "type": "array", "items": { "type": "string" }, "default": [] },
        "must_avoid": { "type": "array", "items": { "type": "string" }, "default": [] },
        "reference_digests": { "type": "array", "items": { "$ref": "#/$defs/digest" }, "default": [] }
      }
    },

    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["systems"],
      "properties": {
        "scenes": { "type": "array", "items": { "type": "string" }, "default": [] },
        "routes": { "type": "array", "items": { "type": "string" }, "default": [] },
        "systems": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "services": { "type": "array", "items": { "type": "string" }, "default": [] },
        "diagram": { "type": "string", "description": "optional mermaid/ascii" }
      }
    },

    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Entity / data model contracts so batches share one definition of the nouns.",
      "properties": {
        "entities": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string" },
              "fields": { "type": "array", "items": { "type": "string" }, "default": [] },
              "behaviors": { "type": "array", "items": { "type": "string" }, "default": [] }
            }
          }
        },
        "data_model": { "type": "array", "items": { "type": "string" }, "default": [] },
        "api_plan": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },

    "asset_manifest": {
      "type": "array",
      "default": [],
      "description": "Every asset/UI element the batches need, named up front (the cure for improvised art).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["sprite", "spritesheet", "tile", "background", "icon", "audio", "font", "component", "page", "other"] },
          "size": { "type": "string" },
          "spec": { "type": "string" }
        }
      }
    },

    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["functional"],
      "properties": {
        "functional": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "visual": { "type": "array", "items": { "type": "string" }, "default": [] },
        "performance": { "type": "array", "items": { "type": "string" }, "default": [] },
        "accessibility": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },

    "batch_roadmap": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered, dependency-aware batches that FIT TOGETHER. Each becomes one `mb next` in Matrix Builder.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "purpose", "allowed_files", "acceptance"],
        "properties": {
          "id": { "type": "string", "pattern": "^batch-[0-9]{2,}$" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "depends_on": { "type": "array", "items": { "type": "string" }, "default": [] },
          "allowed_files": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "new_features": { "type": "array", "items": { "type": "string" }, "default": [] },
          "must_not_change": { "type": "array", "items": { "type": "string" }, "default": [] },
          "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },

    "governance": {
      "type": "object",
      "additionalProperties": false,
      "description": "Which design-packs / Matrix Definitions rules this brain was validated against.",
      "properties": {
        "design_packs": { "type": "array", "items": { "type": "string" }, "default": [] },
        "rules_applied": { "type": "array", "items": { "type": "string" }, "default": [] },
        "validation_status": { "type": "string", "enum": ["not-run", "approved", "needs-repair", "rejected"], "default": "not-run" }
      }
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "ai_assisted"],
      "properties": {
        "created_by": { "type": "string", "minLength": 1 },
        "ai_assisted": { "type": "boolean" },
        "model": { "type": "string" },
        "design_digest": { "$ref": "#/$defs/digest" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "qualityLevel": { "type": "string", "enum": ["starter", "standard", "production", "enterprise"] },
    "digest": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{16,}$" }
  }
}
